VITE_API_URL=http://localhost:3000
# Must match GOOGLE_CLIENT_ID below.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend
FRONTEND_BASE_URL=http://localhost:5173
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Use a strong random value in production.
SESSION_SECRET=change-this-session-secret
COOKIE_SECURE=false
# Default share link TTL (7 days).
SHARE_LINK_TTL_SECONDS=604800

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=thumbnail_fastee
MYSQL_CONNECTION_LIMIT=10
# Run backend migrations from repo root:
# npm run db:migrate

# Redis (use URL or host/port/password)
REDIS_URL=redis://127.0.0.1:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
